# Telegram Bot Token (получите у @BotFather)
BOT_TOKEN=your_bot_token_here

# URL вашего веб-приложения (для Telegram Web App)
APP_URL=https://your_domain.com

# URL вебхука (если используется)
WEBHOOK_URL=https://your_domain.com/webhook

# Порт сервера
PORT=3000

# Режим окружения (development, production)
NODE_ENV=development

# База данных (если будет использоваться)
# DATABASE_URL=postgresql://user:password@localhost:5432/database_name

# Секретные ключи (для production)
# SESSION_SECRET=your_session_secret
# JWT_SECRET=your_jwt_secret